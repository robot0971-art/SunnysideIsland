# =====================
# Unity
# =====================
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore
Unity/[Ll]ibrary/
Unity/[Tt]emp/
Unity/[Oo]bj/
Unity/[Bb]uild/
Unity/[Bb]uilds/
Unity/[Ll]ogs/
Unity/[Uu]ser[Ss]ettings/

# MemoryCaptures can get excessive
Unity/[Mm]emoryCaptures/

# Recorded songs can get excessive
Unity/[Rr]ecordings/

# External editor temp files
*.csproj
*.unityproj
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Builds
*.apk
*.unitypackage
*.app

# Crashlytics generated file
crashlytics-build.properties

# =====================
# Node.js (WebBackend)
# =====================
# Dependencies
WebBackend/node_modules/

# Environment
WebBackend/.env

# Database
WebBackend/db/*.db

# Logs
*.log
npm-debug.log*

# =====================
# OS generated
# =====================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db